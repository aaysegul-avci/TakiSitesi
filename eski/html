<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Esinsüs Süs ve Organizasyon E-Ticaret Sitesi">
    <title>Esinsüs Süs ve Organizasyon</title>
    <style>
        /* Genel stil */
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
        }

        header {
            background-color: #333;
            color: white;
            padding: 10px 0;
            text-align: center;
        }

        header nav ul {
            list-style-type: none;
            padding: 0;
        }

        header nav ul li {
            display: inline;
            margin: 0 20px;
        }

        header nav ul li a {
            color: white;
            text-decoration: none;
        }

        h2 {
            color: #333;
            text-align: center;
        }

        /* Ürünler */
        .product-list {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
        }

        .product-item {
            background-color: white;
            padding: 15px;
            text-align: center;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 200px;
        }

        .product-item img {
            width: 100%;
            height: auto;
        }

        .add-to-cart {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 10px;
            cursor: pointer;
        }

        .add-to-cart:hover {
            background-color: #218838;
        }

        /* Form */
        form {
            width: 50%;
            margin: 0 auto;
        }

        form input, form textarea {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid